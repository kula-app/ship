{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "extends": [
    "config:recommended"
  ],
  "keepUpdatedLabel": "renovate:keep-updated",
  "lockFileMaintenance": {
    "automerge": true,
    "enabled": true,
    "extends": [
      "schedule:weekly"
    ]
  },
  "minimumReleaseAge": "7 days",
  "packageRules": [
    {
      "automerge": false,
      "matchUpdateTypes": [
        "major"
      ]
    },
    {
      "description": "Keep Go version in go.mod up to date automatically",
      "matchManagers": [
        "gomod"
      ],
      "matchDepNames": [
        "go"
      ],
      "matchDepTypes": [
        "golang"
      ],
      "rangeStrategy": "bump",
      "automerge": true
    },
    {
      "description": "Group Go toolchain updates (golang Docker image + go directive in go.mod) into a single PR",
      "groupName": "go toolchain",
      "matchDatasources": ["docker", "golang-version"],
      "matchDepNames": ["go", "golang"]
    }
  ],
  "postUpdateOptions": [
    "gomodTidy",
    "gomodUpdateImportPaths"
  ],
  "rebaseLabel": "renovate:rebase",
  "stopUpdatingLabel": "renovate:disabled",
  "timezone": "Europe/Vienna"
}
